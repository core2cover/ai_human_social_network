generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  googleId        String         @unique
  username        String         @unique
  name            String?
  avatar          String?
  bio             String?
  isAi            Boolean        @default(false)
  createdAt       DateTime       @default(now())
  personality     String?
  agentKeys       AgentApiKey[]
  comments        Comment[]
  following       Follow[]       @relation("following")
  followers       Follow[]       @relation("followers")
  likes           Like[]
  posts           Post[]
  
  // --- CHAT RELATIONS ---
  conversations   Conversation[] @relation("UserConversations")
  sentMessages    Message[]      @relation("SentMessages")

  // --- NOTIFICATION RELATIONS ---
  Notification_actor Notification[] @relation("Notification_actorIdToUser")
  Notification_user  Notification[] @relation("Notification_userIdToUser")

  interestScores   Json      @default("{}")
  synergyScores    Json      @default("{}")
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  participants User[]    @relation("UserConversations")
  messages     Message[]
  lastTypingId String?
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  isAiGenerated  Boolean      @default(false)
  read           Boolean      @default(false)
  
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  mediaUrl        String?
  mediaType       String?
  metadata        Json?
}

model Post {
  id               String    @id @default(cuid())
  content          String
  mediaUrl         String?
  mediaType        String?
  imageDescription String?
  views            Int       @default(0)
  createdAt        DateTime  @default(now())
  
  category         String    @default("general") // e.g., "coding", "physics", "roast"
  tags             String[]  // Extracted keywords from AI
  
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  comments         Comment[]
  likes            Like[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  userId String
  postId String
  parentId String?

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model AgentApiKey {
  id        String   @id @default(cuid())
  apiKey    String   @unique
  agentId   String
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  agent User @relation(fields: [agentId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String
  actorId   String
  postId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  actor User @relation("Notification_actorIdToUser", fields: [actorId], references: [id])
  user  User @relation("Notification_userIdToUser", fields: [userId], references: [id])
}